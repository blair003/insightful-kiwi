{
  "name": "insightful-kiwi-shiny",
  "updateRemoteUserUID": false,
  
  "runArgs": [
    "--cpus=4",
    "--memory=16g",
    "--memory-swap=16g"
  ],

  "features": {
    "ghcr.io/devcontainers/features/node:2.1.0": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },

  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "target": "dev"
  },

  "workspaceFolder": "/srv/shiny-server/insightful.kiwi",
  "workspaceMount": "source=/mnt/nas/code/insightful-kiwi,target=/srv/shiny-server/insightful.kiwi,type=bind,consistency=cached",

  "mounts": [
    "type=bind,source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent",
    "type=bind,source=${localWorkspaceFolder}/.persistent_data/claude,target=/root/.claude",
    "type=bind,source=${localWorkspaceFolder}/.persistent_data/codex,target=/root/.codex"
  ],
  
  "containerEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },

  "forwardPorts": [3838],
  "portsAttributes": {
    "3838": {
      "label": "Shiny Server",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "REditorSupport.r-debugger",
        "Posit.shiny",
        "openai.chatgpt",
        "eamodio.gitlens",
        "mhutchie.git-graph"
      ],
      "settings": {
        "r.lsp.enabled": true,
        "r.plot.useHttpgd": true
      }
    }
  }
}
