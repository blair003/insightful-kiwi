{
  "name": "insightful-kiwi-shiny",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "target": "dev"
  },
  "workspaceFolder": "/srv/shiny-server/insightful.kiwi",
  "workspaceMount": "source=${localWorkspaceFolder},target=/srv/shiny-server/insightful.kiwi,type=bind,consistency=cached",

  "mounts": [
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind"
  ],
  "containerEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },

  "forwardPorts": [3838],
  "portsAttributes": {
    "3838": {
      "label": "Shiny Server",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "REditorSupport.r-debugger",
        "Posit.shiny",
        "openai.chatgpt",
        "anthropic.claude-code"
      ],
      "settings": {
        "r.lsp.enabled": true,
        "r.plot.useHttpgd": true
      }
    }
  }
}
