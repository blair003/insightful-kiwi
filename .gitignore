# R / RStudio
.Rproj.user/
.Rhistory
.RData
.Rprofile
.Renviron
.Ruserdata/
*.Rproj

# OS / editor
.DS_Store
.vscode/
.positai/
.lintr

# Instance config: commit only selected config files
instance/config/*
!instance/config/base.R
!instance/config/project.R
!instance/config/environment.R

# Instance runtime/generated
instance/cache/
instance/app_cache/
instance/logs/

# Generated media cache: keep dir placeholder, ignore files
instance/www/media-cache/*
!instance/www/media-cache/.gitkeep

# Track symlinks in www/, so do NOT ignore these:
# www/media-cache
# www/project-images

# Runtime temp
temp/
tangential/