# -------------------------------------------------------------------
# Application Data, Caches, and Logs
# -------------------------------------------------------------------

# No 
instance/cache/
instance/app_cache/
instance/logs/
docs/data-model
docs/dev
docs/reference
# Raw data directory (untracked as requested)
instance/extdata/raw/

# Ignore all configs except the core required files
instance/config/*
!instance/config/project.R
!instance/config/datasets.R

# Ignore media cache contents but keep the folder via .gitkeep
instance/www/media-cache/*
!instance/www/media-cache/.gitkeep

# -------------------------------------------------------------------
# Environment & OS files
# -------------------------------------------------------------------
app_cache/
.DS_Store
.vscode/
.claude
.positai/

# -------------------------------------------------------------------
# R / RStudio specific files
# -------------------------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Rprofile
.Renviron
.Ruserdata/
*.Rproj
.lintrdocs/